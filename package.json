{
  "name": "netbridge",
  "version": "0.1.3",
  "description": "The network tab your server never had. Zero-config inspector for server-side HTTP traffic (fetch, axios, ky, got) in Next.js and any Node.js app — bodies included.",
  "keywords": [
    "debug",
    "devtools",
    "network",
    "http",
    "proxy",
    "inspector",
    "nextjs",
    "fetch",
    "axios",
    "server-side"
  ],
  "license": "MIT",
  "author": "Muhammed Oguz <muhammed0748@outlook.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muhammedogz/netbridge.git"
  },
  "type": "commonjs",
  "bin": {
    "netbridge": "dist/cli.js"
  },
  "main": "dist/preload.js",
  "files": [
    "dist",
    "ui",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && vite build --config ui-src/vite.config.ts",
    "build:cli": "tsc",
    "build:ui": "vite build --config ui-src/vite.config.ts",
    "dev:ui": "vite --config ui-src/vite.config.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "node test/smoke.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
